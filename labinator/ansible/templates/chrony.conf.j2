# /etc/chrony/chrony.conf
# Managed by vm-onboard — do not edit manually
# Generated: {{ ansible_date_time.iso8601 }}

# NTP servers (from config.yaml ntp.servers)
{% for server in ntp_servers %}
server {{ server }} iburst
{% endfor %}

# Drift file
driftfile /var/lib/chrony/drift

# Allow system clock to be stepped in the first 3 clock updates
makestep 1.0 3

# Enable kernel clock synchronization
rtcsync

# Minimum number of selectable sources
minsources 2

# Log directory
logdir /var/log/chrony
