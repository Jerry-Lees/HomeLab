# /etc/snmp/snmpd.conf
# Auto-generated by deploy_lxc.py on {{ deploy_date }}
# Host: {{ hostname }}
# ============================================================

# --- Agent settings ---
# Listen on all interfaces, port 161 UDP (IPv4 and IPv6)
agentaddress udp:161,udp6:[::1]:161

# --- System information ---
sysLocation     {{ snmp_location }}
sysContact      {{ snmp_contact }}
sysDescr        {{ hostname }} - Ubuntu Linux - auto-deployed

# --- Community access ---
# Read-Write access with community "{{ snmp_community }}" from any source
rwcommunity     {{ snmp_community }}    {{ snmp_source }}
# Also set rocommunity for tools that only test read access
rocommunity     {{ snmp_community }}    {{ snmp_source }}

# IPv6 equivalents
rwcommunity6    {{ snmp_community }}    {{ snmp_source }}
rocommunity6    {{ snmp_community }}    {{ snmp_source }}

# --- Disk monitoring (alert if < 10% free) ---
includeAllDisks 10%

# --- Load monitoring (1min, 5min, 15min thresholds) ---
load 12 10 8

# --- Interface monitoring ---
# Allow ifTable/ifXTable to be queried
pass_persist .1.3.6.1.2.1.2 /usr/bin/snmp-bridge-mib

# --- Logging ---
# Log to syslog rather than a file (visible via journalctl)
# (default behaviour on Ubuntu systemd systems)
