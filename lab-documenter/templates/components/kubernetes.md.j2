{% if kubernetes_info %}
## Kubernetes
{% if kubernetes_info.kubectl_version %}
- **Version:** {{ kubernetes_info.kubectl_version }}
{% endif %}

{% if kubernetes_info.namespaces %}
### Namespaces ({{ kubernetes_info.namespaces|length }})
{% for namespace in kubernetes_info.namespaces|sort %}
- {{ namespace }}
{% endfor %}
{% endif %}

{% if kubernetes_info.nodes %}
### Nodes ({{ kubernetes_info.nodes|length }})

| Node | Roles | Status | Taints |
|------|-------|--------|--------|
{% for node in kubernetes_info.nodes %}
| **{{ node.name or 'Unknown' }}** | {{ node.roles or 'Unknown' }} | {{ 'Ready' if node.status == 'Ready' else 'NotReady' }} | {{ node.taints or '' }} |
{% endfor %}

{% endif %}

{% if kubernetes_info.pods %}
{% set running_pods = kubernetes_info.pods | selectattr('status', 'equalto', 'Running') | list %}
### Pods Summary
- **Total Pods:** {{ kubernetes_info.pods|length }}
- **Running:** {{ running_pods|length }}

<details>
<summary><strong>All Pods by Namespace ({{ kubernetes_info.pods|length }} total)</strong></summary>

{% set pods_by_namespace = kubernetes_info.pods | groupby('namespace') %}
{% for namespace, namespace_pods in pods_by_namespace %}
#### {{ namespace }} ({{ namespace_pods|list|length }} pods)

|  | Name | Status | Ready | Restarts | Age |
|--|------|--------|-------|---------|-----|
{% for pod in namespace_pods|list|sort(attribute='name') %}
| {{ '✅' if pod.status == 'Running' else '❌' if pod.status in ['Failed', 'Error', 'CrashLoopBackOff'] else '⚠️' }} | **{{ pod.name or 'Unknown' }}** | {{ pod.status or 'Unknown' }} | {{ pod.ready or 'Unknown' }} | {{ pod.restarts or '0' }} | {{ pod.age or 'Unknown' }} |
{% endfor %}

{% endfor %}
</details>

{% if kubernetes_info.problematic_pods %}
{% if kubernetes_info.problematic_pods|length <= 8 %}
#### Issues Found
| Namespace/Pod | Status | Ready | Restarts |
|---------------|--------|-------|---------|
{% for pod in kubernetes_info.problematic_pods %}
| **{{ pod.namespace or 'Unknown' }}/{{ pod.name or 'Unknown' }}** | {{ pod.status or 'Unknown' }} | {{ pod.ready or 'Unknown' }} | {{ pod.restarts or 'Unknown' }} |
{% endfor %}
{% else %}
<details>
<summary><strong>Issues Found ({{ kubernetes_info.problematic_pods|length }} total)</strong></summary>

| Namespace/Pod | Status | Ready | Restarts |
|---------------|--------|-------|---------|
{% for pod in kubernetes_info.problematic_pods %}
| **{{ pod.namespace or 'Unknown' }}/{{ pod.name or 'Unknown' }}** | {{ pod.status or 'Unknown' }} | {{ pod.ready or 'Unknown' }} | {{ pod.restarts or 'Unknown' }} |
{% endfor %}

</details>
{% endif %}
{% endif %}
{% endif %}

{% if kubernetes_info.services %}
### Kubernetes Services ({{ kubernetes_info.services|length }})
{% if kubernetes_info.services|length <= 8 %}
| Namespace/Name | Type | Cluster IP | External IP | Ports |
|----------------|------|------------|-------------|-------|
{% for svc in kubernetes_info.services %}
| **{{ svc.namespace or 'Unknown' }}/{{ svc.name or 'Unknown' }}** | {{ svc.type or 'Unknown' }} | {{ svc.cluster_ip or 'Unknown' }} | {{ svc.external_ip or '' }} | {{ (svc.ports or '') | replace(',', '<br>') }} |
{% endfor %}
{% else %}
<details>
<summary><strong>Kubernetes Services ({{ kubernetes_info.services|length }} total)</strong></summary>

| Namespace/Name | Type | Cluster IP | External IP | Ports |
|----------------|------|------------|-------------|-------|
{% for svc in kubernetes_info.services %}
| **{{ svc.namespace or 'Unknown' }}/{{ svc.name or 'Unknown' }}** | {{ svc.type or 'Unknown' }} | {{ svc.cluster_ip or 'Unknown' }} | {{ svc.external_ip or '' }} | {{ (svc.ports or '') | replace(',', '<br>') }} |
{% endfor %}

</details>
{% endif %}
{% endif %}

{% if kubernetes_info.deployments %}
### Deployments
{% set deps_by_namespace = kubernetes_info.deployments | groupby('namespace') %}
{% if kubernetes_info.deployments|length <= 8 %}
{% for namespace, namespace_deps in deps_by_namespace %}
#### {{ namespace }} ({{ namespace_deps|list|length }} deployments)

| Name | Ready | Up-to-date | Available |
|------|-------|-----------|---------|
{% for dep in namespace_deps|list|sort(attribute='name') %}
| **{{ dep.name or 'Unknown' }}** | {{ dep.ready or 'Unknown' }} | {{ dep.up_to_date or 'Unknown' }} | {{ dep.available or 'Unknown' }} |
{% endfor %}

{% endfor %}
{% else %}
<details>
<summary><strong>All Deployments ({{ kubernetes_info.deployments|length }} total)</strong></summary>

{% for namespace, namespace_deps in deps_by_namespace %}
#### {{ namespace }} ({{ namespace_deps|list|length }} deployments)

| Name | Ready | Up-to-date | Available |
|------|-------|-----------|---------|
{% for dep in namespace_deps|list|sort(attribute='name') %}
| **{{ dep.name or 'Unknown' }}** | {{ dep.ready or 'Unknown' }} | {{ dep.up_to_date or 'Unknown' }} | {{ dep.available or 'Unknown' }} |
{% endfor %}

{% endfor %}
</details>
{% endif %}
{% endif %}

{% endif %}
