{% if bigip_info %}
== F5 BIG-IP ==

{% if bigip_info.version_info %}
{% set v = bigip_info.version_info %}
* '''Product:''' {{ v.product or 'BIG-IP' }}
* '''Version:''' {{ v.version or 'Unknown' }}{% if v.build %} (Build {{ v.build }}){% endif %}

{% if v.edition %}
* '''Edition:''' {{ v.edition }}
{% endif %}
{% endif %}

{% if bigip_info.ha_status and bigip_info.ha_status.state %}
* '''HA State:''' {{ bigip_info.ha_status.state }}
{% endif %}

{% if bigip_info.virtual_servers %}
=== Virtual Servers ({{ bigip_info.virtual_servers|length }}) ===
{% if bigip_info.virtual_servers|length <= 8 %}
{| class='wikitable sortable'
|-
! Name !! Destination !! Protocol !! Pool
{% for vs in bigip_info.virtual_servers %}
|-
| '''{{ vs.name or 'Unknown' }}''' || {{ vs.destination or '' }} || {{ vs.protocol or '' }} || {{ vs.pool or '' }}
{% endfor %}
|}
{% else %}
{| class='wikitable sortable mw-collapsible mw-collapsed'
|+ Virtual Servers ({{ bigip_info.virtual_servers|length }} total)
|-
! Name !! Destination !! Protocol !! Pool
{% for vs in bigip_info.virtual_servers %}
|-
| '''{{ vs.name or 'Unknown' }}''' || {{ vs.destination or '' }} || {{ vs.protocol or '' }} || {{ vs.pool or '' }}
{% endfor %}
|}
{% endif %}
{% endif %}

{% if bigip_info.pools %}
=== Pools ({{ bigip_info.pools|length }}) ===
{% if bigip_info.pools|length <= 8 %}
{| class='wikitable sortable'
|-
! Name !! Members !! Monitor !! LB Method
{% for pool in bigip_info.pools %}
|-
| '''{{ pool.name or 'Unknown' }}''' || {{ pool.member_count or 0 }} || {{ pool.monitor or '' }} || {{ pool.lb_method or '' }}
{% endfor %}
|}
{% else %}
{| class='wikitable sortable mw-collapsible mw-collapsed'
|+ Pools ({{ bigip_info.pools|length }} total)
|-
! Name !! Members !! Monitor !! LB Method
{% for pool in bigip_info.pools %}
|-
| '''{{ pool.name or 'Unknown' }}''' || {{ pool.member_count or 0 }} || {{ pool.monitor or '' }} || {{ pool.lb_method or '' }}
{% endfor %}
|}
{% endif %}
{% endif %}

{% if bigip_info.interfaces %}
=== Interfaces ===
{| class='wikitable sortable'
|-
! Name !! Status !! Media !! Bits In !! Bits Out
{% for iface in bigip_info.interfaces %}
|-
| '''{{ iface.name or 'Unknown' }}''' || {{ iface.status or 'Unknown' }} || {{ iface.media or '' }} || {{ iface.bits_in or '' }} || {{ iface.bits_out or '' }}
{% endfor %}
|}
{% endif %}

{% if bigip_info.vlans %}
=== VLANs ({{ bigip_info.vlans|length }}) ===
{| class='wikitable sortable'
|-
! Name !! Tag !! Interfaces
{% for vlan in bigip_info.vlans %}
|-
| '''{{ vlan.name or 'Unknown' }}''' || {{ vlan.tag or '' }} || {{ vlan.interfaces | join(', ') if vlan.interfaces else '' }}
{% endfor %}
|}
{% endif %}

{% endif %}
