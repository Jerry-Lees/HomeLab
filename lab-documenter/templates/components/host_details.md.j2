{% if login_history %}
## Login History
{% if login_history.last_boot %}
- **Last Boot:** {{ login_history.last_boot }}
{% endif %}
{% if login_history.logins %}
| User | Terminal | From | When |
|------|----------|------|------|
{% for login in login_history.logins %}
| {{ login.user }} | {{ login.terminal }} | {{ login.from }} | {{ login.when }} |
{% endfor %}
{% endif %}

{% endif %}

{% if local_users %}
## Local Users
{% if local_users|length <= 8 %}
| Username | Full Name | Shell | Sudo |
|----------|-----------|-------|------|
{% for u in local_users %}
| **{{ u.username }}** | {{ u.full_name }} | {{ u.shell }} | {{ '✅ Yes' if u.sudo else 'No' }} |
{% endfor %}
{% else %}
<details>
<summary><strong>Local Users ({{ local_users|length }} total)</strong></summary>

| Username | Full Name | Shell | Sudo |
|----------|-----------|-------|------|
{% for u in local_users %}
| **{{ u.username }}** | {{ u.full_name }} | {{ u.shell }} | {{ '✅ Yes' if u.sudo else 'No' }} |
{% endfor %}

</details>
{% endif %}

{% endif %}

{% if cron_jobs %}
## Scheduled Tasks (Cron)
{% if cron_jobs|length <= 8 %}
| Source | Entry |
|--------|-------|
{% for job in cron_jobs %}
| `{{ job.source }}` | `{{ job.entry }}` |
{% endfor %}
{% else %}
<details>
<summary><strong>Scheduled Tasks ({{ cron_jobs|length }} total)</strong></summary>

| Source | Entry |
|--------|-------|
{% for job in cron_jobs %}
| `{{ job.source }}` | `{{ job.entry }}` |
{% endfor %}

</details>
{% endif %}

{% endif %}

{% if firewall_info %}
## Firewall
- **Type:** {{ firewall_info.type | title }}
- **Status:** {{ firewall_info.status | title }}
{% if firewall_info.rules_text %}
<details>
<summary><strong>Firewall Rules</strong></summary>

```
{{ firewall_info.rules_text }}
```

</details>
{% endif %}

{% endif %}

{% if installed_packages %}
## Installed Packages ({{ installed_packages|length }})
{% if installed_packages|length <= 20 %}
| Package | Version |
|---------|---------|
{% for pkg in installed_packages %}
| {{ pkg.name }} | {{ pkg.version }} |
{% endfor %}
{% else %}
<details>
<summary><strong>Installed Packages ({{ installed_packages|length }} total)</strong></summary>

| Package | Version |
|---------|---------|
{% for pkg in installed_packages %}
| {{ pkg.name }} | {{ pkg.version }} |
{% endfor %}

</details>
{% endif %}

{% endif %}
